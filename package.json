{
  "name": "mn-analise",
  "displayName": "mn-analise",
  "publisher": "Yuri Viana",
  "description": "Local AI code analyzer using Ollama",
  "version": "5.0.4",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": ["Other"],
  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "mn-analise.analyzeCodeCommand",
        "title": "Search vulnerabilities"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mnAnaliseViewContainer",
          "title": "MN Analise"
        }
      ]
    },
    "views": {
      "mnAnaliseViewContainer": [
        {
          "id": "mnAnaliseView",
          "name": "MN Analise"
        }
      ]
    },
"configuration": {
  "title": "MN-Analise",
  "properties": {
    "mn-analise.language": {
      "type": "string",
      "default": "English",
      "enum": ["English", "Português (BR)"]
    },

    "mn-analise.aiProvider": {
      "type": "string",
      "default": "anthropic",
      "enum": ["anthropic", "ollama"],
      "description": "AI provider"
    },

    "mn-analise.03.anthropicApiKey": {
      "type": "string",
      "default": "",
      "description": "Anthropic API key (Claude)"
    },

    "mn-analise.05.ollamaModel": {
      "type": "string",
      "default": "llama3",
      "description": "Ollama model (llama3, codellama, mistral)"
    },

    "mn-analise.06.ollamaEndpoint": {
      "type": "string",
      "default": "http://localhost:11434/v1/messages",
      "description": "Ollama Anthropic-compatible endpoint"
    }
  }
}
  },

  "scripts": {
    "lint": "eslint ."
  },

  "dependencies": {
  }
}