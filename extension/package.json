{
  "name": "mn-analise",
  "displayName": "mn-analise-yuri",
  "publisher": "Yuri Viana",
  "description": "AI code analyzer with multiple providers",
  "version": "6.0.0",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": ["Other"],
  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "mn-analise.analyzeCodeCommand",
        "title": "Search vulnerabilities"
      }
    ],

    "configuration": {
      "title": "MN-Analise",
      "properties": {

        "mn-analise.01.language": {
          "type": "string",
          "default": "English",
          "enum": ["English", "Português (BR)"]
        },

        "mn-analise.02.aiProvider": {
          "type": "string",
          "default": "ollama",
          "enum": ["ollama", "anthropic", "mistral", "qwen"]
        },

        "mn-analise.03.anthropicApiKey": {
          "type": "string",
          "default": ""
        },

        "mn-analise.04.mistralApiKey": {
          "type": "string",
          "default": ""
        },

        "mn-analise.05.ollamaModel": {
          "type": "string",
          "default": "llama3"
        },

        "mn-analise.06.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/generate"
        },

        "mn-analise.07.qwenApiKey": {
          "type": "string",
          "default": ""
        }
      }
    }
  },

  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}